@model IEnumerable<APIwebbanhangnhe.Models.Category>
@{
    ViewData["Title"] = "Danh mục";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Category Management</span>
        <h1>Danh muc the cau thu</h1>
    </div>
    <a class="btn btn-warning" asp-action="Add">Them category</a>
</div>

<div class="panel-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Ten danh muc</th>
                    <th>Mo ta</th>
                    <th>Thu tu</th>
                    <th>So the</th>
                    <th class="text-end">Thao tac</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model)
                {
                    <tr>
                        <td class="fw-semibold">@category.Name</td>
                        <td class="text-muted">@category.Description</td>
                        <td>@category.DisplayOrder</td>
                        <td>@category.PlayerCards.Count</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-dark" asp-action="Display" asp-route-id="@category.Id">Xem</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Update" asp-route-id="@category.Id">Sua</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@category.Id">Xoa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
