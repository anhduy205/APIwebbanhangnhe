@model APIwebbanhangnhe.Models.Category
@{
    ViewData["Title"] = "Cập nhật danh mục";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Category</span>
        <h1>Cap nhat danh muc</h1>
    </div>
    <a class="btn btn-outline-dark" asp-action="Index">Quay lai</a>
</div>

<form asp-action="Update" method="post" class="panel-card form-shell">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="row g-3">
        <div class="col-md-8">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="DisplayOrder" class="form-label"></label>
            <input asp-for="DisplayOrder" class="form-control" />
            <span asp-validation-for="DisplayOrder" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" rows="4" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
    </div>
    <div class="action-row">
        <button type="submit" class="btn btn-warning">Cap nhat</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Huy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
