@model APIwebbanhangnhe.Models.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Lesson 6 RESTful API";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">RESTful API</span>
        <h1>Lesson 6 - Product CRUD API</h1>
        <p class="text-muted mb-0">
            Project nay da duoc bo sung Product REST API, Swagger va giao dien CRUD de goi API theo dung bai 6.
        </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary" href="/swagger">Open Swagger</a>
        <a class="btn btn-outline-primary" href="/product-crud-demo/index.html">Open Product Demo</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="panel-card h-100">
            <h2 class="h4">API endpoints</h2>
            <ul class="mb-0">
                <li><code>GET /api/products</code> - get all products</li>
                <li><code>GET /api/products/{id}</code> - get product details</li>
                <li><code>POST /api/products</code> - create product</li>
                <li><code>PUT /api/products/{id}</code> - update product</li>
                <li><code>DELETE /api/products/{id}</code> - delete product</li>
            </ul>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="panel-card h-100">
            <h2 class="h4">Quick notes</h2>
            <ul class="mb-0">
                <li>Swagger opens automatically when the API starts in Development.</li>
                <li>The frontend page supports add, edit, view and delete product.</li>
                <li>CORS is enabled for Live Server on <code>localhost:5500</code> and <code>127.0.0.1:5500</code>.</li>
            </ul>
        </div>
    </div>
</div>
