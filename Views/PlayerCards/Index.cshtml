@model IEnumerable<APIwebbanhangnhe.Models.PlayerCard>
@{
    ViewData["Title"] = "Thẻ cầu thủ";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Player Cards</span>
        <h1>Quan ly the cau thu</h1>
    </div>
    <a class="btn btn-warning" asp-action="Add">Them the moi</a>
</div>

<div class="panel-card">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Anh</th>
                    <th>The</th>
                    <th>Danh muc</th>
                    <th>Gia</th>
                    <th>Gallery</th>
                    <th class="text-end">Thao tac</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var card in Model)
                {
                    <tr>
                        <td>
                            <img src="@card.ImageUrl" alt="@card.PlayerName" class="thumb-image" />
                        </td>
                        <td>
                            <div class="fw-semibold">@card.Title</div>
                            <div class="text-muted">@card.PlayerName • @card.Position</div>
                        </td>
                        <td>@card.Category?.Name</td>
                        <td class="fw-semibold">@card.Price.ToString("N0") VNĐ</td>
                        <td>@card.Images.Count ảnh</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-dark" asp-action="Display" asp-route-id="@card.Id">Xem</a>
                            <a class="btn btn-sm btn-outline-primary" asp-action="Update" asp-route-id="@card.Id">Sua</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@card.Id">Xoa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
