@model APIwebbanhangnhe.Models.ViewModels.PlayerCardFormViewModel
@{
    ViewData["Title"] = "Cập nhật thẻ cầu thủ";
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Update Card</span>
        <h1>Cap nhat the cau thu</h1>
    </div>
    <a class="btn btn-outline-dark" asp-action="Index">Quay lai</a>
</div>

<form asp-action="Update" method="post" enctype="multipart/form-data" class="form-shell">
    <input type="hidden" asp-for="Id" />
    <partial name="_Form" model="Model" />
    <div class="action-row">
        <button type="submit" class="btn btn-warning">Cap nhat</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Huy</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
