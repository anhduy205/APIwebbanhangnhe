@model APIwebbanhangnhe.Models.ViewModels.PlayerCardFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="editor-grid">
    <section class="panel-card">
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="PlayerName" class="form-label"></label>
                <input asp-for="PlayerName" class="form-control" />
                <span asp-validation-for="PlayerName" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Club" class="form-label"></label>
                <input asp-for="Club" class="form-control" />
                <span asp-validation-for="Club" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Position" class="form-label"></label>
                <input asp-for="Position" class="form-control" />
                <span asp-validation-for="Position" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Rarity" class="form-label"></label>
                <input asp-for="Rarity" class="form-control" />
                <span asp-validation-for="Rarity" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>
            <div class="col-md-8">
                <label asp-for="CategoryId" class="form-label"></label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" rows="4" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="panel-card">
        <div class="row g-3">
            <div class="col-12">
                <label asp-for="ThumbnailFile" class="form-label"></label>
                <input asp-for="ThumbnailFile" type="file" class="form-control" />
                <span asp-validation-for="ThumbnailFile" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" class="form-control" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>
            <div class="col-12">
                <label asp-for="GalleryFiles" class="form-label"></label>
                <input asp-for="GalleryFiles" type="file" multiple class="form-control" />
                <span asp-validation-for="GalleryFiles" class="text-danger"></span>
                <small class="text-muted">Anh moi se duoc them vao gallery hien co.</small>
            </div>
            <div class="col-12">
                <div class="preview-box">
                    <span class="eyebrow">Preview</span>
                    <img src="@Model.CurrentImageUrl" alt="Preview" class="preview-image" />
                </div>
            </div>
            @if (Model.ExistingImages.Any())
            {
                <div class="col-12">
                    <span class="eyebrow">Gallery hien co</span>
                    <div class="gallery-grid">
                        @foreach (var image in Model.ExistingImages)
                        {
                            <img src="@image.Url" alt="Gallery image" class="gallery-thumb" />
                        }
                    </div>
                </div>
            }
        </div>
    </section>
</div>
